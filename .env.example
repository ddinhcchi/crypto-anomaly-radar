# Default symbols to scan (comma-separated, Binance spot tickers)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT

# Candle interval: 1m, 5m, 15m, 1h, 4h, 1d
INTERVAL=1m

# Rolling window for z-score baseline (number of candles)
ZSCORE_WINDOW=60

# |z| above this counts as an anomaly
ZSCORE_THRESHOLD=3.0

# IsolationForest contamination (fraction of points treated as outliers)
IF_CONTAMINATION=0.02

# ATR-based range expansion filter — catches wick spikes that z-score misses
ATR_WINDOW=14
ATR_MULTIPLIER=2.5

# Telegram alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Seconds between alerts for the same symbol
ALERT_COOLDOWN_SECONDS=300
